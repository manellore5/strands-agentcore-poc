# Copy this file to .env and fill in real values. NEVER commit the .env itself.
# In production (AgentCore Runtime), these values come from the
# --environment-variables flag instead of a .env file.

# Anthropic API key (get from https://console.anthropic.com)
# Starts with sk-ant-api03-...
ANTHROPIC_API_KEY=replace-with-your-actual-key

# Optional — override the model used (defaults to claude-haiku-4-5 in code)
# MODEL_ID=claude-haiku-4-5

# Optional — override the listening port (defaults to 8080)
# PORT=8080
